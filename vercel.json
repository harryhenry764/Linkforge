{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/app/main.py" },
    { "source": "/docs", "destination": "/backend/app/main.py" },
    { "source": "/openapi.json", "destination": "/backend/app/main.py" },
    { "source": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|html))", "destination": "/frontend/$1" },
    { "source": "/(.*)", "destination": "/frontend/index.html" }
  ],
  "builds": [
    { "src": "backend/app/main.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ]
}
